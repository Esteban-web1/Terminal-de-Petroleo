{
  "rewrites": [
    { "source": "/", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ],
  "functions": {
    "api/prices.js":         { "maxDuration": 10 },
    "api/prices-alpha.js":   { "maxDuration": 10 },
    "api/news-gnews.js":     { "maxDuration": 10 },
    "api/news-newsapi.js":   { "maxDuration": 10 },
    "api/eia-data.js":       { "maxDuration": 10 },
    "api/ai-analysis.js":    { "maxDuration": 30 }
  }
}
